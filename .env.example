NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/keuwo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
AUTH_ISSUER=keuwo-api
AUTH_AUDIENCE=keuwo-clients
ACCESS_TOKEN_SECRET=change-me-please
REFRESH_TOKEN_SECRET=change-me-too-please
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
TWO_FA_CODE_TTL_SECONDS=300
TWO_FA_VERIFICATION_TOKEN_TTL_SECONDS=600
TWO_FA_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
TWO_FA_TOKEN_SECRET=change-me-two-fa
SEED_USER_EMAIL=admin@keuwo.local
SEED_USER_PASSWORD=Admin1234!

# Notifications
RESEND_API_KEY=
RESEND_FROM_EMAIL=Keuwo <no-reply@keuwo.local>
FRONTEND_VERIFY_EMAIL_URL=http://localhost:3001/confirm-email

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_REGION=us-east-1
S3_MEDIA_BUCKET=keuwo-media
S3_DOCUMENTS_BUCKET=keuwo-documents
CDN_BASE_URL=http://localhost:8080

# Kafka
KAFKA_ENABLED=false
KAFKA_BROKERS=
